# DigiDocs Mgt 生产环境模板
# 复制为 .env 后再执行 docker compose --profile app up -d --build

POSTGRES_DB=digidocs_mgt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_PORT=15432

APP_NAME=DigiDocs Mgt Go API
HTTP_ADDR=:8080
APP_ENV=production
API_V1_PREFIX=/api/v1
DATA_BACKEND=postgres
DATABASE_URL=postgres://postgres:replace-with-strong-password@postgres:5432/digidocs_mgt?sslmode=disable
BACKEND_GO_PORT=18081

JWT_SECRET=replace-with-strong-random-secret
WORKER_CALLBACK_TOKEN=replace-with-strong-internal-token
CORS_ALLOW_ORIGINS=http://localhost:18080

STORAGE_BACKEND=synology
# P14s 与群晖在同一局域网时，建议填写群晖 LAN IP / 内网 DNS，而不是 Tailscale 100.x 地址。
SYNOLOGY_HOST=192.168.1.10
SYNOLOGY_PORT=5001
SYNOLOGY_HTTPS=true
SYNOLOGY_INSECURE_SKIP_VERIFY=false
SYNOLOGY_ACCOUNT=digidocs_service
SYNOLOGY_PASSWORD=replace-with-synology-password
SYNOLOGY_SHARE_PATH=/DigiDocs

WORKER_NAME=digidocs-py-worker
WORKER_MODE=distributed
# 标准 Linux compose 会注入 host-gateway 映射；若 Docker bridge 到宿主机端口受限，请使用 docker-compose.p14s.yml。
OPENCLAW_BASE_URL=http://host.docker.internal:18789
# 使用 docker-compose.p14s.yml 时，会优先读取以下 P14S_* 覆盖值，让 Worker 通过 host network 访问宿主机本地端口。
P14S_OPENCLAW_BASE_URL=http://127.0.0.1:18789
P14S_CALLBACK_BASE_URL=http://127.0.0.1:18081
OPENCLAW_API_KEY=replace-with-openclaw-token
OPENCLAW_MODEL=openclaw/default
OPENCLAW_BACKEND_MODEL=
OPENCLAW_TIMEOUT_SECONDS=60
CALLBACK_BASE_URL=http://backend-go:8080
CALLBACK_TOKEN=replace-with-strong-internal-token
POLL_INTERVAL=5

FRONTEND_PORT=18080
