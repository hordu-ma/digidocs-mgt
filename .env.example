# ============================================================
# DigiDocs Mgt — 环境变量模板
# 复制为 .env 后根据实际环境修改
# ============================================================

# ---------- 基础设施 ----------

# PostgreSQL
POSTGRES_DB=digidocs_mgt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---------- backend-go ----------

APP_NAME=DigiDocs Mgt Go API
HTTP_ADDR=:8080
APP_ENV=development          # development | production
API_V1_PREFIX=/api/v1
DATA_BACKEND=postgres        # memory | postgres
DATABASE_URL=postgres://postgres:postgres@localhost:15432/digidocs_mgt?sslmode=disable

# 安全：生产环境必须换成高强度随机值
JWT_SECRET=dev-secret
WORKER_CALLBACK_TOKEN=replace-me

# CORS 允许的源，逗号分隔；开发环境可设为 *
CORS_ALLOW_ORIGINS=*

# Storage backend: memory | synology
STORAGE_BACKEND=memory

# Synology DSM connection (required when STORAGE_BACKEND=synology)
SYNOLOGY_HOST=
SYNOLOGY_PORT=5000
SYNOLOGY_HTTPS=false
SYNOLOGY_ACCOUNT=
SYNOLOGY_PASSWORD=
SYNOLOGY_SHARE_PATH=/DigiDocs

# ---------- backend-py-worker ----------

WORKER_NAME=digidocs-py-worker
WORKER_MODE=local            # local | distributed
OPENCLAW_BASE_URL=http://localhost:8001
OPENCLAW_API_KEY=replace-me
CALLBACK_BASE_URL=http://localhost:8080
CALLBACK_TOKEN=replace-me
POLL_INTERVAL=5

# ---------- Frontend ----------

VITE_API_BASE_URL=http://localhost:18081/api/v1

