# ============================================================
# DigiDocs Mgt — 环境变量模板
# 复制为 .env 后根据实际环境修改
# ============================================================

# ---------- 基础设施 ----------

# PostgreSQL
POSTGRES_DB=digidocs_mgt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=15432

# ---------- backend-go ----------

APP_NAME=DigiDocs Mgt Go API
HTTP_ADDR=:8080
APP_ENV=development          # development | production
API_V1_PREFIX=/api/v1
DATA_BACKEND=postgres        # memory | postgres
DATABASE_URL=postgres://postgres:postgres@localhost:15432/digidocs_mgt?sslmode=disable
BACKEND_GO_PORT=18081
CODE_REPO_ROOT=/tmp/digidocs-code-repos

# 安全：生产环境必须换成高强度随机值
JWT_SECRET=dev-secret
WORKER_CALLBACK_TOKEN=replace-me

# CORS 允许的源，逗号分隔；开发环境可设为 *
CORS_ALLOW_ORIGINS=*

# Storage backend: memory | synology
STORAGE_BACKEND=memory

# Synology DSM connection (required when STORAGE_BACKEND=synology)
# P14s 与群晖在同一局域网时，建议填写群晖 LAN IP / 内网 DNS，而不是 Tailscale 100.x 地址。
SYNOLOGY_HOST=
SYNOLOGY_PORT=5000
SYNOLOGY_HTTPS=false
SYNOLOGY_INSECURE_SKIP_VERIFY=false
SYNOLOGY_ACCOUNT=
SYNOLOGY_PASSWORD=
SYNOLOGY_SHARE_PATH=/DigiDocs

# ---------- backend-py-worker ----------

WORKER_NAME=digidocs-py-worker
WORKER_MODE=local            # local | distributed
OPENCLAW_BASE_URL=http://localhost:18789
# 使用 docker-compose.p14s.yml 时，会优先读取以下 P14S_* 覆盖值。
P14S_OPENCLAW_BASE_URL=http://127.0.0.1:18789
P14S_CALLBACK_BASE_URL=http://127.0.0.1:18081
OPENCLAW_API_KEY=replace-me
OPENCLAW_MODEL=openclaw/default
OPENCLAW_BACKEND_MODEL=
OPENCLAW_TIMEOUT_SECONDS=60
OPENCLAW_SKILLS_ASSISTANT_ASK=answer_with_context
OPENCLAW_SKILLS_DOCUMENT_SUMMARIZE=document_summary
OPENCLAW_SKILLS_HANDOVER_SUMMARIZE=handover_summary
OPENCLAW_SKILLS_GENERATE_SUGGESTION=structured_suggestion
CALLBACK_BASE_URL=http://localhost:8080
CALLBACK_TOKEN=replace-me      # 建议与 WORKER_CALLBACK_TOKEN 保持一致
POLL_INTERVAL=5

# ---------- Frontend ----------

FRONTEND_PORT=18080
VITE_API_BASE_URL=http://localhost:18081/api/v1
